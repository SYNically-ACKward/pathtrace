{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PathTrace",
  "version": "0.1.0",
  "identifier": "org.thenetworkguy.pathtrace",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "PathTrace",
        "width": 1000,
        "height": 680,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
